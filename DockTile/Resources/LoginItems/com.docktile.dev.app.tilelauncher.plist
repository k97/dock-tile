<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Dev launcher agent. Same as release but targets the "Dock Tile Dev" executable. -->
	<key>Label</key>
	<string>com.docktile.dev.app.tilelauncher</string>
	<key>BundleProgram</key>
	<string>Contents/MacOS/Dock Tile Dev</string>
	<key>ProgramArguments</key>
	<array>
		<string>Contents/MacOS/Dock Tile Dev</string>
		<string>--login-spawn-tiles</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>LimitLoadToSessionType</key>
	<string>Aqua</string>
</dict>
</plist>
