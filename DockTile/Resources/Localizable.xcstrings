    "alert.missingApps.message": {
      "comment": "Alert message offering to remove uninstalled apps from tiles",
      "extractionState": "manual",
      "localizations": {
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Some apps in your tiles can't be found on this Mac. Remove them from your tiles?"
